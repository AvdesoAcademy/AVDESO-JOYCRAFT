      }
    }
  }
    if( (( (tdir + 1) % 4 == dir ) || ( (dir + 1) % 4 == tdir ))&&hold&&tdir!=-1) {
      dir=tdir;
      tone(9,(dir*10+50)*sound,50);
      hold=0;
    }
  if (frame>=600) {
    if (X<0 || X>=128 || Y<0 || Y>=64) {
      gameover(0);
      score=length;
    }
    setMove(head, dir);
    head = (head + 1) % 256;
    X=X+cosTable[dir]*8;
