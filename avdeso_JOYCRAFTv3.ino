    for (int i=0;i<length;i++) {
      if (x==X && y==Y && i>0) {
        gameover(0);
        score=length;
      }
      display.fillRect(x, y, 8, 8, SSD1306_WHITE);
      d=getMove((head-i+255)%256);
      x=x-cosTable[d]*8;
      y=y-sinTable[d]*8;
    }
    display.drawRect(appleX*8, appleY*8, 8, 8, SSD1306_WHITE);
    display.setTextSize(1);
    display.setTextColor(SSD1306_WHITE);
    display.setCursor(10,56);
    display.display();
    frame=0;
    hold=1;
