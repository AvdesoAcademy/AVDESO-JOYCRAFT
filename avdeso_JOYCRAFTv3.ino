void apple() {
  bool valid=0;
  while (!valid) {
    valid=1;
    appleX=random(0,15);
    appleY=random(0,7);
    int x=X;
    int y=Y;
    int d=0;
      for (int i=0;i<length;i++) {
        if (x==appleX*8 && y==appleY*8) {
          valid=0;
        }
        d=getMove((head-i+255)%256);
        x=x-cosTable[d]*8;
        y=y-sinTable[d]*8;
      }
    }
  }
void setMove(int index, uint8_t dir) {
  int byteIndex = index >> 2;      // index / 4
  int shift = (index & 3) * 2;     // (index % 4) * 2

  moves[byteIndex] &= ~(0b11 << shift);   // clear old
  moves[byteIndex] |= (dir & 0b11) << shift;
  }
uint8_t getMove(int index) {
  int byteIndex = index >> 2;
  int shift = (index & 3) * 2;

  return (moves[byteIndex] >> shift) & 0b11;
  }

void gamebegin () {
  randomSeed(analogRead(A0));
  if (menuL==0) {
    X=32;
    Y=32;
    dir=0;
    length=1;
    appleX=12;
    appleY=4;
  }
  else if (menuL==1) {
    X=32;
    Y=32;
    dir=0;
    dY=3;
    length=-1;
    for (int i=0;i<256;i++) {
      setMove(i,random(0,4));
    }
  }
  else if (menuL==2) {
    X=32;
    appleX=-12;
    appleY=4;
    length=0;
    for (int i=0;i<256;i++) {
      setMove(i,3);
    }
    counter=0;
    difficulty=0;
  }
    frame=0;
    head=0;
    hold=1;
    game=1;
    respawnDelay=0;
    death=0;
    score=0;
  }

